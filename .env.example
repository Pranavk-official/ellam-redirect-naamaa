# Copy to `.env` for local dev, and set the same vars in your deploy environment.

# Absolute URL the site is served from — used for OG / link-preview image URLs.
# On Vercel LEAVE THIS UNSET: it auto-detects the production URL (and your
# custom domain once added). Set it only to override, e.g. a non-Vercel host.
# NEXT_PUBLIC_SITE_URL=https://ellam.in

# Open naamaa.in listing links in a new tab. "true" = new tab, anything else = same tab.
NEXT_PUBLIC_OPEN_IN_NEW_TAB=true
