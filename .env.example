# Copy to `.env` for local dev, and set the same vars in your deploy environment.

# Public URL where the site is actually served. Used to build absolute OG /
# link-preview image URLs — it MUST match the serving host or previews break.
# Use the current host now; change to https://ellam.in on cutover.
NEXT_PUBLIC_SITE_URL=https://ellam.naamaa.in

# Open naamaa.in listing links in a new tab. "true" = new tab, anything else = same tab.
NEXT_PUBLIC_OPEN_IN_NEW_TAB=true
